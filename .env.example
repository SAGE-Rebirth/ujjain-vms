# Razorpay test keys — get them free at https://dashboard.razorpay.com → Settings → API Keys
# Copy this file to `.env` and fill both values, then restart the backend.
# With both set, the citizen payment opens the real Razorpay checkout.
# Leave them blank/absent → server runs in MOCK mode (instant booking, no popup).
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
