# Razorpay test keys — get them free at https://dashboard.razorpay.com → Settings → API Keys
# Copy this file to `.env` and fill both values, then restart the backend.
# With both set, the citizen payment opens the real Razorpay checkout.
# Leave them blank/absent → server runs in MOCK mode (instant booking, no popup).
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# MongoDB cloud mirror (optional) — local-first: SQLite stays the source of truth,
# and data is pushed up to MongoDB Atlas opportunistically. Get a free cluster at
# https://www.mongodb.com/atlas → create a DB user → "Connect" → drivers → copy URI.
# Paste the full SRV connection string (with your own user:pass) into MONGO_URI.
# Leave MONGO_URI blank/absent → mirror is OFF, app runs fully local as before.
MONGO_URI=
MONGO_DB=ujjain_vms
MONGO_SYNC_INTERVAL=30
